    }
    .section__title { font-size: 32px; font-weight: 700; margin-bottom: 8px; }
    .section__subtitle { font-size: 16px; color: var(--text-secondary); margin-bottom: 48px; }

    /* Module preview grid */
    .modules-preview {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
    }
    @media (max-width: 900px) {
      .modules-preview { grid-template-columns: repeat(2, 1fr); }
    }

    .module-preview-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 14px; padding: 24px;
      position: relative; overflow: hidden;
      text-decoration: none; color: inherit;
      transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }
    .module-preview-card:hover {
      background: var(--bg-card-hover);
      border-color: var(--border-light);
      transform: translateY(-2px);
    }
    .module-preview-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: var(--mod-color);
    }
    .module-preview-card__icon { font-size: 28px; margin-bottom: 12px; }
    .module-preview-card__code {
      font-family: var(--font-mono); font-size: 10px;
      color: var(--text-muted); margin-bottom: 4px;
    }
    .module-preview-card__title { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
    .module-preview-card__desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
    .module-preview-card__status {
      margin-top: 16px; font-family: var(--font-mono);
      font-size: 10px; color: var(--mod-color);
    }

    /* ── Waarom gratis sectie ── */
    .why-section {
      background: var(--bg-surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 80px 48px;
      text-align: center;
    }
    .why-section__inner { max-width: 640px; margin: 0 auto; }
    .why-section__title { font-size: 28px; font-weight: 700; margin-bottom: 20px; }
    .why-section__text { font-size: 16px; color: var(--text-secondary); line-height: 1.8; margin-bottom: 32px; }

    /* ── Footer ── */
    .footer {
      padding: 40px 48px;
      border-top: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: center;
      font-size: 13px; color: var(--text-muted);
      max-width: 1100px; margin: 0 auto;
