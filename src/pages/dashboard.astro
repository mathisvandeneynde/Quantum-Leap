    </div>
    <a href="/modules/sr/sr-03" class="btn-primary">Continue →</a>
  </div>


  <!-- --------------------------------------------------------------
       STATS BAR
       Getallen worden later dynamisch via progress.js
       -------------------------------------------------------------- -->
  <div class="stats-bar">
    <div class="stat-card">
      <div class="stat-card__icon">✅</div>
      <div>
        <div class="stat-card__value" id="stat-lessons">3</div>
        <div class="stat-card__label">Lessons completed</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-card__icon">⏱️</div>
      <div>
        <div class="stat-card__value" id="stat-time">4.2h</div>
        <div class="stat-card__label">Study time</div>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-card__icon">📚</div>
      <div>
        <div class="stat-card__value">1 / 6</div>
        <div class="stat-card__label">Modules active</div>
      </div>
    </div>
  </div>


  <!-- --------------------------------------------------------------
       MODULE GRID
       Status aanpassen: badge--progress / badge--available / badge--soon
       Voortgangsbalk: verander width % en "X of Y done"
       -------------------------------------------------------------- -->
