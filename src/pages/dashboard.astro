---
// ============================================================
// dashboard.astro  —  /dashboard
// ============================================================
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard · Quantum Leap Physics</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/Quantum-Leap/assets/css/global.css" />
  <style>
    :root { --mod-color: var(--accent-gold); }
  </style>
</head>
<body>

<!-- ================================================================
     SIDEBAR
     ================================================================ -->
<aside class="sidebar">
  <div class="sidebar__logo">
    <div class="sidebar__logo-wordmark">Quantum<span>Leap</span></div>
    <div class="sidebar__logo-sub">Physics Platform</div>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">Core modules</div>
    <a class="nav-item active" href="/Quantum-Leap/dashboard">
      <span class="nav-item__icon">🏠</span> Dashboard
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/ana">
      <span class="nav-item__icon" style="color:var(--mod-ana)">📐</span> Analytical Mechanics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/cft">
      <span class="nav-item__icon" style="color:var(--mod-cft)">🌊</span> Classical Field Theory
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/ced">
      <span class="nav-item__icon" style="color:var(--mod-ced)">⚡</span> Classical Electrodynamics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/sr">
      <span class="nav-item__icon" style="color:var(--mod-sr)">🚀</span> Special Relativity
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/qm">
      <span class="nav-item__icon" style="color:var(--mod-qm)">🌀</span> Quantum Mechanics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/sm">
      <span class="nav-item__icon" style="color:var(--mod-sm)">🌡️</span> Statistical Mechanics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/qft">
      <span class="nav-item__icon" style="color:var(--mod-qft)">✴️</span> Quantum Field Theory
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/std">
      <span class="nav-item__icon" style="color:var(--mod-std)">⚛️</span> Standard Model
    </a>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">My Progress</div>
    <a class="nav-item" href="#"><span class="nav-item__icon">📊</span> Activity</a>
    <a class="nav-item" href="#"><span class="nav-item__icon">🗺️</span> Knowledge Map</a>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">Account</div>
    <a class="nav-item" href="/Quantum-Leap/"><span class="nav-item__icon">🌐</span> Homepage</a>
    <a class="nav-item" href="#"><span class="nav-item__icon">⚙️</span> Settings</a>
    <a class="nav-item" href="https://patreon.com/quantumleapphysics" target="_blank">
      <span class="nav-item__icon">❤️</span> Patreon
    </a>
  </div>

  <div class="sidebar__user">
    <div class="sidebar__avatar">M</div>
    <div>
      <div class="sidebar__user-name">Mathis</div>
      <div class="sidebar__user-role">Supporter</div>
    </div>
  </div>
</aside>


<!-- ================================================================
     HEADER
     ================================================================ -->
<header class="header">
  <div class="header__title">Dashboard</div>
  <div class="header__right">
    <div class="streak-badge">🔥 7-day streak</div>
    <a href="/Quantum-Leap/" class="btn-outline">← Homepage</a>
  </div>
</header>


<!-- ================================================================
     MAIN
     ================================================================ -->
<main class="main-dashboard">

  <!-- ── Continue banner ── -->
  <div class="continue-banner">
    <div class="continue-banner__icon">📐</div>
    <div class="continue-banner__body">
      <div class="continue-banner__label">Continue where you left off</div>
      <div class="continue-banner__lesson">ANA-03 · The Euler-Lagrange Equations</div>
      <div class="continue-banner__desc">Deriving equations of motion from the action principle — without a single force.</div>
    </div>
    <a href="/Quantum-Leap/modules/ana/ana-03" class="btn-primary">Continue →</a>
  </div>


  <!-- ================================================================
       CORE MODULES — 2-kolomsgrid
       ================================================================ -->
  <div class="section-header">
    <h2 class="section-title">Core modules</h2>
    <a class="section-link" href="#">See full curriculum →</a>
  </div>

  <div class="modules-grid">

    <!-- MODULE 1 — Analytical Mechanics · IN PROGRESS -->
    <a class="module-card" href="/Quantum-Leap/modules/ana"
       style="--mod-color:var(--mod-ana); text-decoration:none; color:inherit;">
      <div class="module-card__top">
        <div class="module-card__icon">📐</div>
        <span class="badge badge--progress">In progress</span>
      </div>
      <div class="module-card__code">Module 1 · ANA</div>
      <div class="module-card__title">Analytical Mechanics</div>
      <div class="module-card__desc">Lagrangian, Hamiltonian, action principle. The deep structure underneath Newtonian mechanics.</div>
      <div class="module-card__meta">
        <span>📄 ~10 lessons</span>
        <span>🕐 ~11h</span>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-track">
          <div class="progress-bar-fill" style="width:25%"></div>
        </div>
        <div class="progress-bar-labels">
          <span class="done">2 of 10 done</span>
          <span class="pct">25%</span>
        </div>
      </div>
    </a>

    <!-- MODULE 2 — Classical Field Theory · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-cft); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">🌊</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 2 · CFT</div>
      <div class="module-card__title">Classical Field Theory</div>
      <div class="module-card__desc">Fields as the continuum limit of particles. Noether's theorem. Symmetry generates conservation laws.</div>
      <div class="module-card__meta">
        <span>📄 ~9 lessons</span>
        <span>🕐 ~10h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 3 — Classical Electrodynamics · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-ced); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">⚡</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 3 · CED</div>
      <div class="module-card__title">Classical Electrodynamics</div>
      <div class="module-card__desc">Maxwell's equations, potentials, radiation. The first complete field theory.</div>
      <div class="module-card__meta">
        <span>📄 ~12 lessons</span>
        <span>🕐 ~14h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 4 — Special Relativity · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-sr); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">🚀</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 4 · SR</div>
      <div class="module-card__title">Special Relativity</div>
      <div class="module-card__desc">Minkowski spacetime, 4-vectors, tensors. The geometry of space and time unified.</div>
      <div class="module-card__meta">
        <span>📄 ~8 lessons</span>
        <span>🕐 ~9h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 5 — Quantum Mechanics · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-qm); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">🌀</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 5 · QM</div>
      <div class="module-card__title">Quantum Mechanics</div>
      <div class="module-card__desc">Hilbert spaces, Schrödinger equation, operators. The world at its smallest scale.</div>
      <div class="module-card__meta">
        <span>📄 ~12 lessons</span>
        <span>🕐 ~14h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 6 — Statistical Mechanics · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-sm); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">🌡️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 6 · SM</div>
      <div class="module-card__title">Statistical Mechanics</div>
      <div class="module-card__desc">Ensembles, entropy, Boltzmann distribution. Thermodynamics derived from first principles.</div>
      <div class="module-card__meta">
        <span>📄 ~10 lessons</span>
        <span>🕐 ~11h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 7 — Quantum Field Theory · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-qft); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">✴️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 7 · QFT</div>
      <div class="module-card__title">Quantum Field Theory</div>
      <div class="module-card__desc">Free fields, interactions, Feynman diagrams. Particles as excitations of quantum fields.</div>
      <div class="module-card__meta">
        <span>📄 ~14 lessons</span>
        <span>🕐 ~18h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 8 — Standard Model · COMING SOON (breed) -->
    <div class="module-card module-card--wide" style="--mod-color:var(--mod-std); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">⚛️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 8 · STD — The Final Destination</div>
      <div class="module-card__title">The Standard Model</div>
      <div class="module-card__desc">Yang-Mills gauge theory, QED, QCD, Higgs mechanism, electroweak unification. The most precisely tested theory in the history of science.</div>
      <div class="module-card__meta">
        <span>📄 ~16 lessons</span>
        <span>🕐 ~20h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

  </div>
  <!-- /CORE MODULES -->


  <!-- ================================================================
       SIDE MODULES — 3-kolomsgrid, gegroepeerd per hoofdmodule
       ================================================================ -->
  <div class="section-header" style="margin-top: 48px;">
    <h2 class="section-title">Side modules
      <span class="section-title__sub">Optional depth — follow your curiosity</span>
    </h2>
  </div>

  <div class="side-modules-grid">

    <!-- Na 1 — Analytical Mechanics -->
    <div class="side-card" style="--mod-color:var(--mod-ana)">
      <div class="side-card__top">
        <div class="side-card__icon">🪐</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">1A · Celestial Mechanics</div>
      <div class="side-card__title">Celestial Mechanics</div>
      <div class="side-card__desc">Kepler orbits, n-body problem, gravitational resonances.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-ana)">
      <div class="side-card__top">
        <div class="side-card__icon">🌪️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">1B · Chaos Theory</div>
      <div class="side-card__title">Chaos & Dynamical Systems</div>
      <div class="side-card__desc">Lyapunov exponents, attractors, bifurcations.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <!-- Na 2 — Classical Field Theory -->
    <div class="side-card" style="--mod-color:var(--mod-cft); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🧱</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">2A · Continuum Mechanics</div>
      <div class="side-card__title">Continuum Mechanics</div>
      <div class="side-card__desc">Elasticity, fluid mechanics, stress tensors.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-cft); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🔊</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">2B · Waves & Acoustics</div>
      <div class="side-card__title">Waves & Acoustics</div>
      <div class="side-card__desc">Dispersion, wave packets, group velocity.</div>
      <div class="side-card__meta"><span>📄 ~5 lessons</span></div>
    </div>

    <!-- Na 3 — Classical Electrodynamics -->
    <div class="side-card" style="--mod-color:var(--mod-ced); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🔭</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">3A · Classical Optics</div>
      <div class="side-card__title">Classical Optics</div>
      <div class="side-card__desc">Interference, diffraction, Fourier methods.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-ced); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">☀️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">3B · Plasma Physics</div>
      <div class="side-card__title">Plasma Physics</div>
      <div class="side-card__desc">MHD, Debye shielding, plasma waves.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <!-- Na 4 — Special Relativity -->
    <div class="side-card" style="--mod-color:var(--mod-sr); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🌌</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">4A · General Relativity</div>
      <div class="side-card__title">General Relativity</div>
      <div class="side-card__desc">Metric, curvature, Einstein field equations.</div>
      <div class="side-card__meta"><span>📄 ~8 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-sr); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🪐</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">4B · Cosmology</div>
      <div class="side-card__title">Cosmology</div>
      <div class="side-card__desc">FLRW metric, expansion, dark energy.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <!-- Na 5 — Quantum Mechanics -->
    <div class="side-card" style="--mod-color:var(--mod-qm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">💻</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">5A · Quantum Information</div>
      <div class="side-card__title">Quantum Information</div>
      <div class="side-card__desc">Qubits, entanglement, quantum computing.</div>
      <div class="side-card__meta"><span>📄 ~7 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-qm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">⚛️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">5B · Atomic & Molecular Physics</div>
      <div class="side-card__title">Atomic & Molecular Physics</div>
      <div class="side-card__desc">Hydrogen atom, fine structure, spectra.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-qm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">💡</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">5C · Quantum Optics</div>
      <div class="side-card__title">Quantum Optics</div>
      <div class="side-card__desc">Laser, coherence, Jaynes-Cummings model.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <!-- Na 6 — Statistical Mechanics -->
    <div class="side-card" style="--mod-color:var(--mod-sm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🔬</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">6A · Solid State Physics</div>
      <div class="side-card__title">Solid State Physics</div>
      <div class="side-card__desc">Band structure, conductivity, Fermi surface.</div>
      <div class="side-card__meta"><span>📄 ~8 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-sm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🧬</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">6B · Biophysics & Complex Systems</div>
      <div class="side-card__title">Biophysics & Complex Systems</div>
      <div class="side-card__desc">Stochastic processes, networks, emergence.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <!-- Na 7 — Quantum Field Theory -->
    <div class="side-card" style="--mod-color:var(--mod-qft); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🧲</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">7A · QFT in Condensed Matter</div>
      <div class="side-card__title">QFT in Condensed Matter</div>
      <div class="side-card__desc">Superconductivity, Hubbard model, phonons.</div>
      <div class="side-card__meta"><span>📄 ~7 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-qft); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🕳️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">7B · Quantum Gravity — Intro</div>
      <div class="side-card__title">Quantum Gravity — Intro</div>
      <div class="side-card__desc">Planck scale, open problems, current directions.</div>
      <div class="side-card__meta"><span>📄 ~5 lessons</span></div>
    </div>

    <!-- Na 8 — Standard Model -->
    <div class="side-card" style="--mod-color:var(--mod-std); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">💥</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">8A · CERN & Particle Experiments</div>
      <div class="side-card__title">CERN & Particle Experiments</div>
      <div class="side-card__desc">Collisions, detectors, cross-sections, discovery physics.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

    <div class="side-card" style="--mod-color:var(--mod-std); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🔮</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">8B · Beyond the Standard Model</div>
      <div class="side-card__title">Beyond the Standard Model</div>
      <div class="side-card__desc">Supersymmetry, string theory, grand unified theories.</div>
      <div class="side-card__meta"><span>📄 ~6 lessons</span></div>
    </div>

  </div>
  <!-- /SIDE MODULES -->

</main>

</body>
</html>
