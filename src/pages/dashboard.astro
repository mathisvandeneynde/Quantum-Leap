---
// ============================================================
// dashboard.astro  —  /dashboard
//
// Wat aanpassen:
//   Continue banner  : lestitel, beschrijving, href
//   Hoofdmodules     : badge, voortgangsbalk
//   Zijmodules       : toevoegen/verwijderen onder de juiste sectie
// ============================================================
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard · Quantum Leap Physics</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/Quantum-Leap/assets/css/global.css" />
  <style>
    :root { --mod-color: var(--accent-gold); }
  </style>
</head>
<body>

<!-- ================================================================
     SIDEBAR
     ================================================================ -->
<aside class="sidebar">

  <div class="sidebar__logo">
    <div class="sidebar__logo-wordmark">Quantum<span>Leap</span></div>
    <div class="sidebar__logo-sub">Physics Platform</div>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">Learn</div>
    <a class="nav-item active" href="/Quantum-Leap/dashboard">
      <span class="nav-item__icon">🏠</span> Dashboard
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/sr">
      <span class="nav-item__icon" style="color:var(--mod-sr)">🚀</span> Special Relativity
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/ana">
      <span class="nav-item__icon" style="color:var(--mod-ana)">📐</span> Analytical Mechanics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/qm">
      <span class="nav-item__icon" style="color:var(--mod-qm)">🌀</span> Quantum Mechanics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/em">
      <span class="nav-item__icon" style="color:var(--mod-em)">⚡</span> Electrodynamics
    </a>
    <a class="nav-item" href="/Quantum-Leap/modules/qft">
      <span class="nav-item__icon" style="color:var(--mod-qft)">✴️</span> Quantum Field Theory
    </a>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">Side Modules</div>
    <a class="nav-item" href="/Quantum-Leap/modules/sm">
      <span class="nav-item__icon" style="color:var(--mod-sm)">🌡️</span> Statistical Mechanics
    </a>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">My Progress</div>
    <a class="nav-item" href="#"><span class="nav-item__icon">📊</span> Activity</a>
    <a class="nav-item" href="#"><span class="nav-item__icon">🗺️</span> Knowledge Map</a>
  </div>

  <div class="sidebar__section">
    <div class="sidebar__section-label">Account</div>
    <a class="nav-item" href="/Quantum-Leap/"><span class="nav-item__icon">🌐</span> Homepage</a>
    <a class="nav-item" href="#"><span class="nav-item__icon">⚙️</span> Settings</a>
    <a class="nav-item" href="https://patreon.com/quantumleapphysics" target="_blank">
      <span class="nav-item__icon">❤️</span> Patreon
    </a>
  </div>

  <div class="sidebar__user">
    <div class="sidebar__avatar">M</div>
    <div>
      <div class="sidebar__user-name">Mathis</div>
      <div class="sidebar__user-role">Supporter</div>
    </div>
  </div>

</aside>


<!-- ================================================================
     HEADER
     ================================================================ -->
<header class="header">
  <div class="header__title">Dashboard</div>
  <div class="header__right">
    <div class="streak-badge">🔥 7-day streak</div>
    <a href="/Quantum-Leap/" class="btn-outline">← Homepage</a>
  </div>
</header>


<!-- ================================================================
     MAIN
     ================================================================ -->
<main class="main-dashboard">

  <!-- ── Continue banner ── -->
  <div class="continue-banner">
    <div class="continue-banner__icon">🚀</div>
    <div class="continue-banner__body">
      <div class="continue-banner__label">Continue where you left off</div>
      <div class="continue-banner__lesson">SR-03 · Time Dilation</div>
      <div class="continue-banner__desc">Moving clocks run slow. The light clock thought experiment is next.</div>
    </div>
    <a href="/Quantum-Leap/modules/sr/sr-03" class="btn-primary">Continue →</a>
  </div>


  <!-- ================================================================
       HOOFDMODULES
       Vaste volgorde van het curriculum — altijd 2 kolommen
       ================================================================ -->
  <div class="section-header">
    <h2 class="section-title">Core modules</h2>
    <a class="section-link" href="#">See full curriculum →</a>
  </div>

  <div class="modules-grid">

    <!-- MODULE 1 — Special Relativity · IN PROGRESS -->
    <a class="module-card" href="/Quantum-Leap/modules/sr"
       style="--mod-color:var(--mod-sr); text-decoration:none; color:inherit;">
      <div class="module-card__top">
        <div class="module-card__icon">🚀</div>
        <span class="badge badge--progress">In progress</span>
      </div>
      <div class="module-card__code">Module 1 · SR</div>
      <div class="module-card__title">Special Relativity</div>
      <div class="module-card__desc">Time dilation, length contraction, E=mc². Why Newton breaks down at high speeds.</div>
      <div class="module-card__meta">
        <span>📄 8 lessons</span>
        <span>🕐 ~9h</span>
      </div>
      <div class="progress-bar-wrap">
        <div class="progress-bar-track">
          <div class="progress-bar-fill" style="width:38%"></div>
        </div>
        <div class="progress-bar-labels">
          <span class="done">3 of 8 done</span>
          <span class="pct">38%</span>
        </div>
      </div>
    </a>

    <!-- MODULE 2 — Analytical Mechanics · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-ana); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">📐</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 2 · ANA</div>
      <div class="module-card__title">Analytical Mechanics</div>
      <div class="module-card__desc">Lagrangian, Hamiltonian, the principle of least action. The deep structure of classical physics.</div>
      <div class="module-card__meta">
        <span>📄 ~10 lessons</span>
        <span>🕐 ~11h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

    <!-- MODULE 3 — Quantum Mechanics · AVAILABLE -->
    <a class="module-card" href="/Quantum-Leap/modules/qm"
       style="--mod-color:var(--mod-qm); text-decoration:none; color:inherit;">
      <div class="module-card__top">
        <div class="module-card__icon">🌀</div>
        <span class="badge badge--available">Available</span>
      </div>
      <div class="module-card__code">Module 3 · QM</div>
      <div class="module-card__title">Quantum Mechanics</div>
      <div class="module-card__desc">Wave functions, superposition, the double-slit experiment. The world at its smallest scale.</div>
      <div class="module-card__meta">
        <span>📄 10 lessons</span>
        <span>🕐 ~12h</span>
      </div>
      <div class="progress-bar-labels" style="margin-top:0">
        <span class="done">Not started</span>
        <span class="module-card__start">Start →</span>
      </div>
    </a>

    <!-- MODULE 4 — Electrodynamics · COMING SOON -->
    <div class="module-card" style="--mod-color:var(--mod-em); opacity:0.6">
      <div class="module-card__top">
        <div class="module-card__icon">⚡</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="module-card__code">Module 4 · EM</div>
      <div class="module-card__title">Electrodynamics</div>
      <div class="module-card__desc">Maxwell's equations, electromagnetic waves, and the deep roots of light.</div>
      <div class="module-card__meta">
        <span>📄 ~12 lessons</span>
        <span>🕐 ~14h</span>
      </div>
      <div class="module-card__action">Coming soon</div>
    </div>

  </div>

  <!-- MODULE 5 — QFT · volledig breed als eindpunt -->
  <div class="module-card module-card--wide" style="--mod-color:var(--mod-qft); opacity:0.6; margin-top:20px;">
    <div class="module-card__top">
      <div class="module-card__icon">✴️</div>
      <span class="badge badge--soon">Coming soon</span>
    </div>
    <div class="module-card__code">Module 5 · QFT</div>
    <div class="module-card__title">Quantum Field Theory</div>
    <div class="module-card__desc">Fields, particles, Feynman diagrams. The language of the Standard Model — the final destination.</div>
    <div class="module-card__meta">
      <span>📄 ~14 lessons</span>
      <span>🕐 ~18h</span>
    </div>
    <div class="module-card__action">Coming soon</div>
  </div>


  <!-- ================================================================
       ZIJMODULES
       Aanvullend, smaller, 3-kolomsgrid
       Nummering: [hoofdmodulenummer][letter] — bv. 3A, 4B
       ================================================================ -->
  <div class="section-header" style="margin-top:48px;">
    <h2 class="section-title">Side modules
      <span class="section-title__sub">Optional depth — follow your curiosity</span>
    </h2>
  </div>

  <div class="side-modules-grid">

    <!-- ZIJMODULE 4A — Statistical Mechanics (bij Module 4: EM → QFT overgang) -->
    <div class="side-card" style="--mod-color:var(--mod-sm); opacity:0.6">
      <div class="side-card__top">
        <div class="side-card__icon">🌡️</div>
        <span class="badge badge--soon">Coming soon</span>
      </div>
      <div class="side-card__code">4A · Statistical Mechanics</div>
      <div class="side-card__title">Statistical Mechanics</div>
      <div class="side-card__desc">Entropy, Boltzmann, thermodynamics from microscopic principles.</div>
      <div class="side-card__meta">
        <span>📄 ~9 lessons</span>
        <span>🕐 ~10h</span>
      </div>
    </div>

    <!--
    ================================================================
    ZIJMODULE TOEVOEGEN — kopieer het blok hierboven en pas aan:
      style="--mod-color: var(--mod-XX)"  → kleur van de verwante module
      side-card__code                     → bv. "4B · Solid State Physics"
      side-card__title                    → naam
      side-card__desc                     → korte beschrijving
    ================================================================
    -->

  </div>

</main>

</body>
</html>
